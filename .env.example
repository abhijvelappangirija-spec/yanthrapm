# Copy this file to .env.local and replace placeholder values.
# Keep real secrets only in .env.local or your deployment secret manager.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI provider selection
# Supported values: perplexity, ollama, dummy
AI_DEFAULT_PROVIDER=perplexity
# AI_BRD_PROVIDER=ollama
# AI_SPRINT_PROVIDER=ollama
# AI_PRIVATE_PROVIDER=ollama
# AI_PRIVATE_TASKS=brd,brd-from-file,sprint-plan
# AI_EXTERNAL_DISABLED=false

# External AI provider: Perplexity
PERPLEXITY_API_KEY=your_perplexity_api_key

# Private/local AI provider: Ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BRD_MODEL=llama3.1:8b
# OLLAMA_SPRINT_MODEL=llama3.1:8b

# Jira Cloud
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_API_TOKEN=your_jira_api_token
# JIRA_STORY_POINTS_FIELD_ID=customfield_13805
# JIRA_EPIC_LINK_FIELD_ID=parent

# Local/dev-only actor fallback
# Leave unset in production.
# APP_ALLOW_FALLBACK_ACTOR=true
# APP_DEFAULT_USER_ID=your_local_test_user_id
# DEMO_USER_ID=your_demo_user_id
# DEFAULT_USER_ID=your_default_user_id
